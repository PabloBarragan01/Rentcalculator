		table _Measures
			lineageTag: 74e0a194-e6df-4ce1-86fb-6727dac96a0f

			measure 'Fecha de Inicio Seleccionada' = max('Inicio'[DateStart])
				formatString: Short Date
				displayFolder: IPC
				lineageTag: eb1fb264-d32a-4f6d-b82c-242674717a21

			measure 'Meses Transcurridos desde el Inicio' =
					
					VAR FechaActual = [FechaActual] // Usamos SELECTEDVALUE aquí para la tarjeta
					VAR FechaInicio = [Fecha de Inicio Seleccionada]
					RETURN
					DATEDIFF(FechaInicio, FechaActual, MONTH)
				formatString: 0
				displayFolder: IPC
				lineageTag: cc139990-e200-4f77-83ca-3fb10349ee73

			measure FechaActual = SELECTEDVALUE(DateTable[firstday])
				formatString: General Date
				displayFolder: IPC
				lineageTag: c52d8830-dd8e-4c66-99ef-a89743ffc2d5

			measure Check =
					
					VAR MesesTranscurridos = [Meses Transcurridos desde el Inicio]
					VAR PeriodoRenovacion = 0 // Usar SELECTEDVALUE
					RETURN
					SWITCH(
					    TRUE(),
					    MesesTranscurridos < 0, 0, // Si los meses transcurridos son negativos, devuelve vacío
					    [Meses Transcurridos desde el Inicio] / Frecuencia[Frecuencia Value] = int([Meses Transcurridos desde el Inicio] / SELECTEDVALUE(Frecuencia[Frecuencia])), 1,
					    0 // En cualquier otro caso (división decimal), devuelve vacío
					)
				displayFolder: IPC
				lineageTag: 2f517a5c-fe45-4321-8fef-cde8f1213ebf

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Amount IPC' =
					--Amount[Amount Value] * (1+[IPC Acumulado])
					            max(Monto[Monto]) * (1+[IPC Acumulado])
				displayFolder: IPC
				lineageTag: 3d95fc21-864b-4df0-af82-e135af679915

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'IPC Acumulado' =
					
					VAR StartDate = MIN(Inicio[DateStart]) -- Fecha seleccionada por el usuario
					VAR CurrentDate = MAX(DateTable[Date]) -- Fecha en la visualización
					RETURN /*
					calculate(max(IPC[ipc_ng_nacional]),
					DateTable[Date] = SELECTEDVALUE(DateTable[firstday]))
					-
					CALCULATE(sum(IPC[ipc_ng_nacional]),
					DateTable[Date] = SELECTEDVALUE(Inicio[DateStart]))
					*/
					
					(DIVIDE(
					CALCULATE(
					    MAX(IPC_data[ipc_ng_nacional]),
					    DateTable[Date] = EDATE(SELECTEDVALUE(DateTable[firstday]), -1)
					),
					CALCULATE(
					    MAX(IPC_data[ipc_ng_nacional]),
					    DateTable[Date] = EDATE(
					            DATE(YEAR(MAX(Inicio[DateStart])), MONTH(MAX(Inicio[DateStart])), 1), -1)
					)
					))-1
				displayFolder: IPC
				lineageTag: 092f130a-f5dd-49b1-8d4c-bd3d15837608

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'IPC grafico' =
					
					/*
					SUM(IPC[IPC]) -
					calculate(sum(IPC[IPC]),
					                dateadd(DateTable[Date],-1,MONTH))
					*/
					sum(IPC_data[ipc_ng_nacional_tasa_variacion_mensual])
				formatString: 0.0%;-0.0%;0.0%
				displayFolder: IPC
				lineageTag: 2f5c464f-e6f5-4013-8916-44cdadf707c5

			measure ColorMeasure =
					
					IF(SUM(IPC_data[ipc_ng_nacional_tasa_variacion_mensual]) -
					calculate(sum(IPC_data[ipc_ng_nacional_tasa_variacion_mensual]),
					                dateadd(DateTable[Date],-1,MONTH)) < 0, "Green", "Red")  -- Green for negative, Red for positive
				displayFolder: IPC
				lineageTag: 53886942-a101-41bc-9260-a1e7ba30b911

			measure 'IPC MoM %' =
					
					SUM(IPC_data[ipc_ng_nacional_tasa_variacion_mensual]) -
					calculate(sum(IPC_data[ipc_ng_nacional_tasa_variacion_mensual]),
					                dateadd(DateTable[Date],-1,MONTH))
				displayFolder: IPC
				lineageTag: 53fa6af6-71a4-48a8-ae7e-7a77cd792866

				formatStringDefinition = "▲0.0%;▼0.0%;0.0%"

			measure 'Max date' = max(IPC_data[indice_tiempo])
				formatString: mmmm yyyy
				lineageTag: 88004e77-8e56-4fcc-b5cf-ab2eccb6fe99

				annotation PBI_FormatHint = {"isDateTimeCustom":true}

			measure CasaPropia_1 =
					
					
					VAR _Monto = max(Monto[Monto])
					VAR _Fecha = max(Inicio[DateStart])
					
					RETURN
					IF(max(DateTable[firstday]) > _Fecha,
					_Monto*max(CasaPropia[Index]),"")
				lineageTag: 64a5f9ff-2833-46f3-9e17-37f0a3322ea6

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure CasaPropia_2 =
					
					VAR __MontoBase = SELECTEDVALUE(Monto[Monto])
					VAR __FechaInicioContrato = SELECTEDVALUE(Inicio[DateStart])
					VAR __FechaContexto = MAX(DateTable[Date]) // Captura la fecha del mes que se está calculando en la visual
					
					// 1. Crear una tabla de factores desde el inicio del contrato hasta la fecha de la fila actual
					VAR __TablaFactores =
					    FILTER(
					        ALL('CasaPropia'), // Ignora filtros externos en la tabla de índices
					        'CasaPropia'[Month-Year] >= __FechaInicioContrato && 'CasaPropia'[Month-Year] <= __FechaContexto
					    )
					
					// 2. Calcular el Factor de Ajuste Acumulado (Productiva de los índices)
					VAR __FactorAcumulado =
					    PRODUCTX(
					        __TablaFactores,
					        'CasaPropia'[Index] // Multiplica todos los valores de 'Index' en el rango
					    )
					
					// 3. Calcular el Alquiler Ajustado
					VAR __MontoAjustado = __MontoBase * __FactorAcumulado
					
					RETURN
					    // Solo devuelve el valor si tenemos un monto base y la fecha actual es posterior o igual a la fecha de inicio
					    IF(
					        NOT ISBLANK(__MontoBase) && __FechaContexto >= __FechaInicioContrato,
					        __MontoAjustado,
					        BLANK()
					    )
				lineageTag: 040336e2-c03d-44da-9cf3-a86d805dcbfe

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Alquiler Ajustado ICASA - FINAL' = ```
					
					// **********************************
					// DECLARACIÓN DE VARIABLES (FUERA DE CUALQUIER IF PRINCIPAL)
					// **********************************
					VAR __MontoBase = SELECTEDVALUE(Monto[Monto])
					VAR __FechaInicioContrato = SELECTEDVALUE(Inicio[DateStart])
					VAR __FechaContexto = MAX(DateTable[Date])
					
					// 1. Establecer el rango de fechas dinámico para el cálculo
					VAR __RangoFechas =
					    DATESBETWEEN(
					        DateTable[Date], // Columna de fecha de la tabla Calendario
					        __FechaInicioContrato,
					        __FechaContexto
					    )
					
					// 2. Calcular el Factor de Ajuste Acumulado (PRODUCTX dentro de CALCULATE)
					VAR __FactorAcumulado =
					    CALCULATE(
					        PRODUCTX(
					            'CasaPropia', // Itera sobre la tabla CasaPropia
					            'CasaPropia'[Index] // Multiplica la columna de índice
					        ),
					        // Aplicamos el rango de fechas calculado
					        REMOVEFILTERS('CasaPropia'),
					        __RangoFechas
					    )
					
					// 3. Calcular el Alquiler Ajustado
					VAR __MontoAjustado = __MontoBase * __FactorAcumulado
					
					// **********************************
					// RETORNO Y VALIDACIONES
					// **********************************
					RETURN
					    // Validación principal: solo calcular si tenemos ambos parámetros y estamos en el período correcto
					
					        __MontoAjustado
					
					    
					```
				lineageTag: 683760cd-1d73-489e-8bd9-716dfa44f6b1

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Medida Prueba Factor Acumulado' = ```
					
					VAR __MontoBase = SELECTEDVALUE(Monto[Monto])
					VAR __FechaInicioContrato = SELECTEDVALUE(Inicio[DateStart])
					VAR __FechaContexto = MAX(DateTable[Date])
					
					// VERIFICACIÓN CLAVE: Si alguno de los parámetros es BLANK, la medida final será BLANK.
					IF(
					    ISBLANK(__MontoBase) || ISBLANK(__FechaInicioContrato),
					    // Si falta un parámetro, retornamos 0 para debugging (o podemos retornar BLANK())
					    0,
					
					    // 1. Establecer el rango de fechas dinámico (DEBE FUNCIONAR SI LAS FECHAS ESTÁN RELACIONADAS)
					    VAR __RangoFechas =
					        DATESBETWEEN(
					            'DateTable'[Date], // Columna de fecha de tu calendario
					            __FechaInicioContrato,
					            __FechaContexto
					        )
					
					    // 2. Calcular el Factor de Ajuste Acumulado (el valor que sospechamos falla)
					    VAR __FactorAcumulado =
					        CALCULATE(
					            PRODUCTX(
					                'CasaPropia',
					                'CasaPropia'[Index]
					            ),
					            REMOVEFILTERS('CasaPropia'),
					            __RangoFechas // Este es el filtro que probablemente no está funcionando
					        )
					    
					    RETURN
					        // Retornamos el Factor Acumulado para verlo en cada fila
					        __FactorAcumulado
					)
					```
				lineageTag: a53cf811-1b4a-48d0-b394-a755107f7daa

			measure 'Alquiler Ajustado ICASA - FINAL V3' = ```
					
					VAR __MontoBase = SELECTEDVALUE(Monto[Monto])
					VAR __FechaInicioContrato = SELECTEDVALUE(Inicio[DateStart])
					VAR __FechaContexto = MAX(DateTable[Date])
					
					VAR __RangoFechas =
					    DATESBETWEEN(
					        'DateTable'[Date], 
					        __FechaInicioContrato,
					        __FechaContexto
					    )
					
					VAR __FactorAcumulado =
					    CALCULATE(
					        PRODUCTX(
					            'CasaPropia', 
					            'CasaPropia'[Index] 
					        ),
					        REMOVEFILTERS('CasaPropia'),
					        __RangoFechas 
					    )
					
					VAR __MontoAjustado = __MontoBase * __FactorAcumulado
					
					RETURN
					        __MontoAjustado
					```
				lineageTag: 83843463-a9ae-48da-a7b1-66ddbf7e0057

				annotation PBI_FormatHint = {"isGeneralNumber":true}

			measure 'Alquiler Ajustado ICASA - ÚLTIMA VERSIÓN' =
					
					// DECLARACIÓN DE VARIABLES
					VAR __MontoBase = max(Monto[Monto])
					VAR __FechaInicioContrato = max(Inicio[DateStart])
					VAR __FechaContexto = MAX(DateTable[Date]) // Fecha de la fila o contexto
					
					// 1. Crear la tabla virtual de factores A PARTIR de la tabla completa de índices
					VAR __TablaFactoresFiltrada =
					    FILTER(
					        ALL('CasaPropia'), // Ignora cualquier filtro externo
					        'CasaPropia'[Month-Year] >= __FechaInicioContrato && 'CasaPropia'[Month-Year] <= __FechaContexto
					    )
					
					// 2. Calcular el Factor de Ajuste Acumulado (Productiva de la tabla filtrada)
					VAR __FactorAcumulado =
					    PRODUCTX(
					        __TablaFactoresFiltrada,
					        'CasaPropia'[Index] // Multiplica la columna de índice
					    )
					
					// 3. Calcular el Alquiler Ajustado
					VAR __MontoAjustado = __MontoBase * __FactorAcumulado
					
					// RETORNO Y VALIDACIÓN DEL RESULTADO
					RETURN
					    // Solo devuelve el monto ajustado si todos los parámetros existen y el mes es correcto
					
					        __MontoAjustado
				lineageTag: ed3ecdf9-5bbb-4373-a43c-75231fb83d0a

				annotation PBI_FormatHint = {"isGeneralNumber":true}

